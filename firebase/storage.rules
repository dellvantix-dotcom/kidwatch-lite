rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Screenshots: authenticated users only
    match /screenshots/{deviceId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB per screenshot
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
